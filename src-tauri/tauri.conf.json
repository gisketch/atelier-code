{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atelier",
  "version": "0.1.0",
  "identifier": "com.gisketch.atelier",
  "build": {
    "beforeDevCommand": "bun run ui:dev -- --port 1420",
    "beforeBuildCommand": "bun run ui:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atelier",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": [
      "../src/daemon/main.ts",
      "../src/daemon/api/index.ts",
      "../src/daemon/observability/index.ts",
      "../src/daemon/orchestration/index.ts",
      "../src/daemon/pr-packet/index.ts",
      "../src/daemon/runner/index.ts",
      "../src/daemon/scheduler/index.ts",
      "../src/daemon/sonata/index.ts",
      "../src/daemon/store/index.ts",
      "../src/daemon/store/migrations/**/*",
      "../src/daemon/workflow/index.ts",
      "../src/daemon/workspace/index.ts",
      "../src/shared/contracts.ts",
      "../package.json",
      "../bun.lock"
    ]
  }
}
